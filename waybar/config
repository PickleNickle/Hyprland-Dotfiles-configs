{
  "layer": "top",
  "position": "top",
  "height": 32,

  "margin-top": 5,
  "margin-bottom": -10,
  "margin-left": 5,
  "margin-right": 5,

  "modules-left": ["tray", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "cpu", "memory"],




  "tray": {
    
  },

  
  
  
   "hyprland/window": {
    "format": "| {title}"

  },





  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "{:%A, %d, %B %Y}"
  },






  "pulseaudio": {
    "format": "🔊 {volume}% |",
  },

  "cpu": {
    "interval": 2,
    "format": "CPU: {usage}% @ {avg_frequency}Ghz |"
  },

  "memory": {
    "format": "RAM: {used}Gib"
  }
}